{
  "name": "@raydenui/ai",
  "version": "0.1.4",
  "description": "AI compatibility layer for Rayden UI - enables LLMs to reliably generate UI without hallucination",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./manifests": {
      "types": "./dist/manifests/index.d.ts",
      "import": "./dist/manifests/index.js",
      "require": "./dist/manifests/index.cjs"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js",
      "require": "./dist/tokens/index.cjs"
    },
    "./anatomy": {
      "types": "./dist/anatomy/index.d.ts",
      "import": "./dist/anatomy/index.js",
      "require": "./dist/anatomy/index.cjs"
    },
    "./recipes": {
      "types": "./dist/recipes/index.d.ts",
      "import": "./dist/recipes/index.js",
      "require": "./dist/recipes/index.cjs"
    },
    "./rules": {
      "types": "./dist/rules/index.d.ts",
      "import": "./dist/rules/index.js",
      "require": "./dist/rules/index.cjs"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js",
      "require": "./dist/mcp/index.cjs"
    },
    "./RAYDEN_RULES.md": "./RAYDEN_RULES.md",
    "./tokens/dtcg": {
      "types": "./dist/tokens/dtcg.d.ts",
      "import": "./dist/tokens/tokens.dtcg.json",
      "require": "./dist/tokens/tokens.dtcg.json"
    },
    "./skills/rayden-use": "./skills/rayden-use/SKILL.md",
    "./references/*": "./references/*"
  },
  "bin": {
    "@raydenui/ai": "./dist/mcp/server.js",
    "rayden-ai-mcp": "./dist/mcp/server.js"
  },
  "files": [
    "dist",
    "skills",
    "references",
    "RAYDEN_RULES.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && tsx scripts/generate-dtcg.ts",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "generate-dtcg": "tsx scripts/generate-dtcg.ts",
    "generate-manifests": "tsx scripts/generate-manifests.ts",
    "validate-manifests": "tsx scripts/validate-manifests.ts"
  },
  "keywords": [
    "ai",
    "llm",
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "gpt",
    "copilot",
    "cursor",
    "windsurf",
    "ai-coding",
    "ai-assistant",
    "code-generation",
    "ui-generation",
    "design-system",
    "component-library",
    "react-components",
    "anti-hallucination",
    "rayden",
    "rayden-ui",
    "rayna-ui",
    "figma",
    "react",
    "tailwindcss",
    "tailwind",
    "typescript",
    "design-tokens",
    "dtcg",
    "w3c-design-tokens",
    "figma-mcp",
    "figma-plugin",
    "design-to-code",
    "code-to-design",
    "ui-kit",
    "component-manifest",
    "component-anatomy",
    "ai-tools",
    "developer-tools"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "@raydenui/ui": ">=0.2.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "ai": {
    "type": "design-system",
    "rulesFile": "RAYDEN_RULES.md",
    "manifestsDir": "dist/manifests",
    "tokensFile": "dist/tokens/tokens.json",
    "tokensDTCGFile": "dist/tokens/tokens.dtcg.json",
    "anatomyDir": "dist/anatomy",
    "skillsDir": "skills",
    "referencesDir": "references",
    "mcpServer": "dist/mcp/server.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/raydenui/rayden"
  }
}
