{
  "$schema": "../schema.json",
  "name": "AvatarGroup",
  "figmaName": "AvatarGroup",
  "description": "Stacked avatar display with overflow indicator.",
  "$relationships": {
    "depends_on": ["Avatar"]
  },

  "anatomy": {
    "root": {
      "type": "FRAME",
      "layoutMode": "HORIZONTAL",
      "layoutAlign": "CENTER",
      "itemSpacing": -8,
      "children": ["avatar-stack", "overflow-indicator"]
    },
    "avatar-stack": {
      "type": "FRAME",
      "layoutMode": "HORIZONTAL",
      "layoutAlign": "CENTER",
      "itemSpacing": -8,
      "children": ["avatar-item"]
    },
    "avatar-item": {
      "type": "INSTANCE",
      "swapProperty": "Avatar",
      "stroke": "{color.white}",
      "strokeWidth": 2
    },
    "overflow-indicator": {
      "type": "FRAME",
      "layoutMode": "HORIZONTAL",
      "layoutAlign": "CENTER",
      "width": 32,
      "height": 32,
      "cornerRadius": "{radius.full}",
      "fill": "{color.grey.100}",
      "stroke": "{color.white}",
      "strokeWidth": 2,
      "optional": true,
      "defaultVisible": false,
      "children": ["overflow-text"]
    },
    "overflow-text": {
      "type": "TEXT",
      "fontFamily": "{typography.fontFamily.sans}",
      "fontWeight": "{typography.fontWeight.medium}",
      "fontSize": "{typography.fontSize.xs}",
      "fill": "{color.grey.600}",
      "textAlignHorizontal": "CENTER",
      "textAlignVertical": "CENTER"
    }
  },

  "sizes": {
    "XS": {
      "avatar-item.width": 24,
      "avatar-item.height": 24,
      "avatar-stack.itemSpacing": -6,
      "overflow-indicator.width": 24,
      "overflow-indicator.height": 24,
      "overflow-text.fontSize": "{typography.fontSize.xxs}"
    },
    "SM": {
      "avatar-item.width": 32,
      "avatar-item.height": 32,
      "avatar-stack.itemSpacing": -8,
      "overflow-indicator.width": 32,
      "overflow-indicator.height": 32,
      "overflow-text.fontSize": "{typography.fontSize.xs}"
    },
    "MD": {
      "avatar-item.width": 40,
      "avatar-item.height": 40,
      "avatar-stack.itemSpacing": -10,
      "overflow-indicator.width": 40,
      "overflow-indicator.height": 40,
      "overflow-text.fontSize": "{typography.fontSize.sm}"
    },
    "LG": {
      "avatar-item.width": 48,
      "avatar-item.height": 48,
      "avatar-stack.itemSpacing": -12,
      "overflow-indicator.width": 48,
      "overflow-indicator.height": 48,
      "overflow-text.fontSize": "{typography.fontSize.base}"
    }
  },

  "variants": {
    "Default": {
      "Default": {
        "overflow-indicator.fill": "{color.grey.100}"
      }
    }
  },

  "componentProperties": [
    {
      "name": "Size",
      "type": "VARIANT",
      "values": ["XS", "SM", "MD", "LG"],
      "default": "MD"
    },
    {
      "name": "Max Visible",
      "type": "TEXT",
      "default": "4"
    },
    {
      "name": "Total Count",
      "type": "TEXT",
      "default": "6"
    },
    {
      "name": "Show Overflow",
      "type": "BOOLEAN",
      "default": true
    }
  ]
}
