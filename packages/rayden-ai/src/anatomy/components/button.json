{
  "$schema": "../schema.json",
  "name": "Button",
  "figmaName": "Button",
  "description": "Primary interactive element for user actions. 8 variants, 2 appearances, 2 sizes.",

  "anatomy": {
    "root": {
      "type": "FRAME",
      "layoutMode": "HORIZONTAL",
      "layoutAlign": "CENTER",
      "primaryAxisSizingMode": "AUTO",
      "counterAxisSizingMode": "AUTO",
      "itemSpacing": "{spacing.2}",
      "paddingHorizontal": "{spacing.4}",
      "paddingVertical": "{spacing.2}",
      "cornerRadius": "{radius.lg}",
      "children": ["icon-leading", "label", "icon-trailing"]
    },
    "label": {
      "type": "TEXT",
      "fontFamily": "{typography.fontFamily.sans}",
      "fontWeight": "{typography.fontWeight.semibold}",
      "fontSize": "{typography.fontSize.sm}",
      "lineHeight": "{typography.lineHeight.normal}",
      "textAlignHorizontal": "CENTER",
      "textAlignVertical": "CENTER"
    },
    "icon-leading": {
      "type": "INSTANCE",
      "optional": true,
      "defaultVisible": false,
      "swapProperty": "Icon Leading",
      "size": 16
    },
    "icon-trailing": {
      "type": "INSTANCE",
      "optional": true,
      "defaultVisible": false,
      "swapProperty": "Icon Trailing",
      "size": 16
    }
  },

  "sizes": {
    "SM": {
      "root.paddingHorizontal": "{spacing.4}",
      "root.paddingVertical": "{spacing.2}",
      "root.height": "36px",
      "label.fontSize": "{typography.fontSize.sm}",
      "icon-leading.size": 16,
      "icon-trailing.size": 16
    },
    "LG": {
      "root.paddingHorizontal": "{spacing.6}",
      "root.paddingVertical": "{spacing.4}",
      "root.height": "56px",
      "label.fontSize": "{typography.fontSize.base}",
      "icon-leading.size": 20,
      "icon-trailing.size": 20
    }
  },

  "variants": {
    "Primary": {
      "Solid": {
        "Default": {
          "root.fill": "{color.primary.500}",
          "label.fill": "{color.grey.50}"
        },
        "Hover": {
          "root.fill": "{color.primary.400}",
          "label.fill": "{color.grey.50}"
        },
        "Focus": {
          "root.fill": "{color.primary.700}",
          "root.stroke": "{color.primary.200}",
          "root.strokeWidth": 2,
          "label.fill": "{color.grey.50}"
        },
        "Disabled": {
          "root.fill": "{color.grey.300}",
          "label.fill": "{color.grey.50}",
          "root.opacity": 1
        }
      },
      "Outlined": {
        "Default": {
          "root.fill": "transparent",
          "root.stroke": "{color.primary.500}",
          "root.strokeWidth": 1,
          "label.fill": "{color.primary.500}"
        },
        "Hover": {
          "root.fill": "{color.primary.50}",
          "root.stroke": "{color.primary.400}",
          "root.strokeWidth": 1,
          "label.fill": "{color.primary.400}"
        },
        "Focus": {
          "root.fill": "transparent",
          "root.stroke": "{color.primary.200}",
          "root.strokeWidth": 2,
          "label.fill": "{color.primary.700}"
        },
        "Disabled": {
          "root.fill": "transparent",
          "root.stroke": "{color.grey.300}",
          "root.strokeWidth": 1,
          "label.fill": "{color.grey.300}"
        }
      }
    },
    "Secondary": {
      "Solid": {
        "Default": {
          "root.fill": "{color.grey.50}",
          "root.stroke": "{color.grey.200}",
          "root.strokeWidth": 1,
          "label.fill": "{color.primary.600}"
        },
        "Hover": {
          "root.fill": "{color.grey.100}",
          "root.stroke": "{color.grey.200}",
          "root.strokeWidth": 1,
          "label.fill": "{color.primary.500}"
        },
        "Focus": {
          "root.fill": "{color.grey.50}",
          "root.stroke": "{color.primary.200}",
          "root.strokeWidth": 2,
          "label.fill": "{color.primary.600}"
        },
        "Disabled": {
          "root.fill": "{color.grey.100}",
          "root.stroke": "{color.grey.200}",
          "root.strokeWidth": 1,
          "label.fill": "{color.grey.400}"
