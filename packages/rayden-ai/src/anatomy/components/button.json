  "componentProperties": [
    {
      "name": "Variant",
      "type": "VARIANT",
      "values": [
        "Primary",
        "Secondary",
        "Grey",
        "Destructive",
        "Text",
        "Success",
        "Warning",
        "Info"
      ],
      "default": "Primary"
    },
    {
      "name": "Appearance",
      "type": "VARIANT",
      "values": ["Solid", "Outlined"],
      "default": "Solid"
    },
    {
      "name": "Size",
      "type": "VARIANT",
      "values": ["SM", "LG"],
      "default": "SM"
    },
    {
      "name": "State",
      "type": "VARIANT",
      "values": ["Default", "Hover", "Focus", "Disabled"],
      "default": "Default"
    },
    {
      "name": "Icon Leading",
      "type": "INSTANCE_SWAP",
      "default": "icon/placeholder"
    },
    {
      "name": "Icon Trailing",
      "type": "INSTANCE_SWAP",
      "default": "icon/placeholder"
    },
    {
      "name": "Show Icon Leading",
      "type": "BOOLEAN",
      "default": false
    },
    {
      "name": "Show Icon Trailing",
      "type": "BOOLEAN",
      "default": false
    },
    {
      "name": "Label",
      "type": "TEXT",
      "default": "Button"
    }
  ]
}
