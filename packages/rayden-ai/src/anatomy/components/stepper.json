{
  "$schema": "../schema.json",
  "name": "Stepper",
  "figmaName": "Stepper",
  "description": "Multi-step progress indicator with dot, number, or icon variants.",

  "anatomy": {
    "root": {
      "type": "FRAME",
      "layoutMode": "HORIZONTAL",
      "layoutAlign": "CENTER",
      "itemSpacing": "{spacing.0}",
      "children": ["step"]
    },
    "step": {
      "type": "FRAME",
      "layoutMode": "HORIZONTAL",
      "layoutAlign": "CENTER",
      "itemSpacing": "{spacing.0}",
      "children": ["step-indicator-container", "connector"]
    },
    "step-indicator-container": {
      "type": "FRAME",
      "layoutMode": "VERTICAL",
      "layoutAlign": "CENTER",
      "itemSpacing": "{spacing.2}",
      "children": ["step-indicator", "step-content"]
    },
    "step-indicator": {
      "type": "FRAME",
      "layoutMode": "HORIZONTAL",
      "layoutAlign": "CENTER",
      "width": 32,
      "height": 32,
      "cornerRadius": "{radius.full}",
      "fill": "{color.grey.100}",
      "stroke": "{color.grey.300}",
      "strokeWidth": 2,
      "children": ["indicator-content"]
    },
    "indicator-content": {
      "type": "FRAME",
      "layoutMode": "HORIZONTAL",
      "layoutAlign": "CENTER",
      "children": ["indicator-dot", "indicator-number", "indicator-icon", "indicator-check"]
    },
    "indicator-dot": {
      "type": "ELLIPSE",
      "width": 8,
      "height": 8,
      "fill": "{color.grey.400}",
      "optional": true,
      "defaultVisible": true
    },
    "indicator-number": {
      "type": "TEXT",
      "fontFamily": "{typography.fontFamily.sans}",
      "fontWeight": "{typography.fontWeight.semibold}",
      "fontSize": "{typography.fontSize.sm}",
      "fill": "{color.grey.600}",
      "textAlignHorizontal": "CENTER",
      "textAlignVertical": "CENTER",
      "optional": true,
      "defaultVisible": false
    },
    "indicator-icon": {
      "type": "INSTANCE",
      "swapProperty": "Step Icon",
      "size": 16,
      "fill": "{color.grey.500}",
      "optional": true,
      "defaultVisible": false
    },
    "indicator-check": {
      "type": "INSTANCE",
      "swapProperty": "Check Icon",
      "size": 16,
      "fill": "{color.white}",
      "optional": true,
      "defaultVisible": false
    },
    "step-content": {
      "type": "FRAME",
      "layoutMode": "VERTICAL",
      "layoutAlign": "CENTER",
      "itemSpacing": "{spacing.0.5}",
      "optional": true,
      "defaultVisible": true,
      "children": ["step-title", "step-description"]
    },
    "step-title": {
      "type": "TEXT",
      "fontFamily": "{typography.fontFamily.sans}",
      "fontWeight": "{typography.fontWeight.medium}",
      "fontSize": "{typography.fontSize.sm}",
      "fill": "{color.grey.700}",
      "textAlignHorizontal": "CENTER"
    },
    "step-description": {
      "type": "TEXT",
      "fontFamily": "{typography.fontFamily.sans}",
      "fontWeight": "{typography.fontWeight.regular}",
      "fontSize": "{typography.fontSize.xs}",
      "fill": "{color.grey.500}",
      "textAlignHorizontal": "CENTER",
      "optional": true,
      "defaultVisible": false
    },
    "connector": {
      "type": "RECTANGLE",
      "height": 2,
      "fill": "{color.grey.200}",
      "layoutGrow": 1
    }
  },

  "variants": {
    "Dot": {
      "Incomplete": {
        "step-indicator.fill": "{color.grey.100}",
        "step-indicator.stroke": "{color.grey.300}",
        "indicator-dot.fill": "{color.grey.400}",
        "indicator-dot.visible": true,
        "indicator-number.visible": false,
        "indicator-icon.visible": false,
        "indicator-check.visible": false
      },
      "Current": {
        "step-indicator.fill": "{color.primary.100}",
        "step-indicator.stroke": "{color.primary.500}",
        "indicator-dot.fill": "{color.primary.500}",
        "indicator-dot.visible": true,
        "step-title.fill": "{color.primary.600}"
      },
      "Complete": {
        "step-indicator.fill": "{color.primary.500}",
        "step-indicator.stroke": "{color.primary.500}",
        "indicator-dot.visible": false,
        "indicator-check.visible": true,
        "connector.fill": "{color.primary.500}"
      }
    },
    "Number": {
      "Incomplete": {
        "step-indicator.fill": "{color.grey.100}",
        "step-indicator.stroke": "{color.grey.300}",
        "indicator-dot.visible": false,
        "indicator-number.visible": true,
        "indicator-number.fill": "{color.grey.600}"
      },
      "Current": {
        "step-indicator.fill": "{color.primary.100}",
        "step-indicator.stroke": "{color.primary.500}",
        "indicator-number.fill": "{color.primary.600}",
        "indicator-number.visible": true,
        "step-title.fill": "{color.primary.600}"
      },
      "Complete": {
        "step-indicator.fill": "{color.primary.500}",
        "step-indicator.stroke": "{color.primary.500}",
        "indicator-number.visible": false,
        "indicator-check.visible": true,
        "connector.fill": "{color.primary.500}"
      }
    },
    "Icon": {
      "Incomplete": {
        "step-indicator.fill": "{color.grey.100}",
        "step-indicator.stroke": "{color.grey.300}",
        "indicator-dot.visible": false,
        "indicator-icon.visible": true,
        "indicator-icon.fill": "{color.grey.500}"
      },
      "Current": {
        "step-indicator.fill": "{color.primary.100}",
        "step-indicator.stroke": "{color.primary.500}",
        "indicator-icon.fill": "{color.primary.600}",
        "indicator-icon.visible": true,
        "step-title.fill": "{color.primary.600}"
      },
      "Complete": {
        "step-indicator.fill": "{color.primary.500}",
        "step-indicator.stroke": "{color.primary.500}",
        "indicator-icon.visible": false,
        "indicator-check.visible": true,
        "connector.fill": "{color.primary.500}"
      }
    }
  },

  "componentProperties": [
    {
      "name": "Indicator",
      "type": "VARIANT",
      "values": ["Dot", "Number", "Icon"],
      "default": "Dot"
    },
    {
      "name": "Orientation",
      "type": "VARIANT",
      "values": ["Horizontal", "Vertical"],
      "default": "Horizontal"
    },
    {
      "name": "Show Labels",
      "type": "BOOLEAN",
      "default": true
    },
    {
      "name": "Show Descriptions",
      "type": "BOOLEAN",
      "default": false
    }
  ]
}
