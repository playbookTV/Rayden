{
  "$schema": "https://raydenui.com/schemas/tokens.json",
  "version": "0.2.1",
  "name": "Rayden UI Design Tokens",
  "description": "Design tokens from Rayna UI Figma design system",

  "colors": {
    "primary": {
      "description": "Primary brand color (orange)",
      "50":  { "hex": "#FFECE5", "tailwind": "primary-50",  "usage": "Light backgrounds, highlights" },
      "75":  { "hex": "#FCD2C2", "tailwind": "primary-75",  "usage": "Hover backgrounds (light)" },
      "100": { "hex": "#FCB59A", "tailwind": "primary-100", "usage": "Light borders, accents" },
      "200": { "hex": "#FA9874", "tailwind": "primary-200", "usage": "Hover accents" },
      "300": { "hex": "#F77A4A", "tailwind": "primary-300", "usage": "Active states" },
      "400": { "hex": "#F56630", "tailwind": "primary-400", "usage": "Button hover" },
      "500": { "hex": "#EB5017", "tailwind": "primary-500", "usage": "Primary button default, main brand" },
      "600": { "hex": "#CC400C", "tailwind": "primary-600", "usage": "Links, text emphasis" },
      "700": { "hex": "#AD3307", "tailwind": "primary-700", "usage": "Focus rings, dark accents" },
      "800": { "hex": "#8F2802", "tailwind": "primary-800", "usage": "Dark backgrounds" },
      "900": { "hex": "#711E00", "tailwind": "primary-900", "usage": "Darkest, high contrast" }
    },
    "secondary": {
      "description": "Secondary color (blue)",
      "50":  { "hex": "#E3EFFC", "tailwind": "secondary-50",  "usage": "Light info backgrounds" },
      "75":  { "hex": "#C6DDF7", "tailwind": "secondary-75",  "usage": "Light info accents" },
      "100": { "hex": "#B6D8FF", "tailwind": "secondary-100", "usage": "Info borders" },
      "200": { "hex": "#80BBFF", "tailwind": "secondary-200", "usage": "Info hover" },
      "300": { "hex": "#3D89DF", "tailwind": "secondary-300", "usage": "Info active" },
      "400": { "hex": "#1671D9", "tailwind": "secondary-400", "usage": "Links, secondary actions" },
      "500": { "hex": "#0D5EBA", "tailwind": "secondary-500", "usage": "Secondary default" },
      "600": { "hex": "#034592", "tailwind": "secondary-600", "usage": "Secondary hover" },
      "700": { "hex": "#04326B", "tailwind": "secondary-700", "usage": "Dark blue accents" },
      "800": { "hex": "#012657", "tailwind": "secondary-800", "usage": "Dark blue backgrounds" },
      "900": { "hex": "#001633", "tailwind": "secondary-900", "usage": "Darkest blue" }
    },
    "grey": {
      "description": "Neutral greys for text, borders, backgrounds",
      "50":  { "hex": "#F9FAFB", "tailwind": "grey-50",  "usage": "Page backgrounds" },
      "75":  { "hex": "#F7F9FC", "tailwind": "grey-75",  "usage": "Card backgrounds" },
      "100": { "hex": "#F0F2F5", "tailwind": "grey-100", "usage": "Disabled backgrounds, dividers" },
      "200": { "hex": "#E4E7EC", "tailwind": "grey-200", "usage": "Borders, separators" },
      "300": { "hex": "#D0D5DD", "tailwind": "grey-300", "usage": "Input borders default" },
      "400": { "hex": "#98A2B3", "tailwind": "grey-400", "usage": "Placeholder text, disabled icons" },
      "500": { "hex": "#667185", "tailwind": "grey-500", "usage": "Secondary text, muted" },
      "600": { "hex": "#475367", "tailwind": "grey-600", "usage": "Body text (alternative)" },
      "700": { "hex": "#344054", "tailwind": "grey-700", "usage": "Body text (primary)" },
      "800": { "hex": "#1D2739", "tailwind": "grey-800", "usage": "Headings, strong text" },
      "900": { "hex": "#101928", "tailwind": "grey-900", "usage": "Highest contrast text" }
    },
    "success": {
      "description": "Success/positive states (green)",
      "50":  { "hex": "#E7F6EC", "tailwind": "success-50",  "usage": "Success backgrounds" },
      "75":  { "hex": "#B5E3C4", "tailwind": "success-75",  "usage": "Success light" },
      "100": { "hex": "#91D6A8", "tailwind": "success-100", "usage": "Success accents" },
      "200": { "hex": "#5FC381", "tailwind": "success-200", "usage": "Success hover (light)" },
      "300": { "hex": "#40B869", "tailwind": "success-300", "usage": "Success active" },
      "400": { "hex": "#0F973D", "tailwind": "success-400", "usage": "Success default" },
      "500": { "hex": "#099137", "tailwind": "success-500", "usage": "Success button, badge" },
      "600": { "hex": "#04802E", "tailwind": "success-600", "usage": "Success hover" },
      "700": { "hex": "#036B26", "tailwind": "success-700", "usage": "Success text" },
      "800": { "hex": "#015B20", "tailwind": "success-800", "usage": "Dark success" },
      "900": { "hex": "#004617", "tailwind": "success-900", "usage": "Darkest success" }
    },
    "error": {
      "description": "Error/destructive states (red)",
      "50":  { "hex": "#FBEAE9", "tailwind": "error-50",  "usage": "Error backgrounds" },
      "75":  { "hex": "#F2BCBA", "tailwind": "error-75",  "usage": "Error light" },
      "100": { "hex": "#EB9B98", "tailwind": "error-100", "usage": "Error accents" },
      "200": { "hex": "#E26E6A", "tailwind": "error-200", "usage": "Error hover (light), borders" },
      "300": { "hex": "#DD524D", "tailwind": "error-300", "usage": "Error active" },
      "400": { "hex": "#D42620", "tailwind": "error-400", "usage": "Error default" },
      "500": { "hex": "#CB1A14", "tailwind": "error-500", "usage": "Destructive button, badge" },
      "600": { "hex": "#BA110B", "tailwind": "error-600", "usage": "Error hover" },
      "700": { "hex": "#9E0A05", "tailwind": "error-700", "usage": "Error text" },
      "800": { "hex": "#800501", "tailwind": "error-800", "usage": "Dark error" }
    },
    "warning": {
      "description": "Warning states (yellow/amber)",
      "50":  { "hex": "#FEF6E7", "tailwind": "warning-50",  "usage": "Warning backgrounds" },
      "75":  { "hex": "#FBE2B7", "tailwind": "warning-75",  "usage": "Warning light" },
      "100": { "hex": "#F7D394", "tailwind": "warning-100", "usage": "Warning accents" },
      "200": { "hex": "#F7C164", "tailwind": "warning-200", "usage": "Warning hover (light)" },
      "300": { "hex": "#F5B546", "tailwind": "warning-300", "usage": "Warning active" },
      "400": { "hex": "#F3A218", "tailwind": "warning-400", "usage": "Warning default, button" },
      "500": { "hex": "#DD900D", "tailwind": "warning-500", "usage": "Warning text" },
      "600": { "hex": "#AD6F07", "tailwind": "warning-600", "usage": "Warning hover" },
      "700": { "hex": "#865503", "tailwind": "warning-700", "usage": "Dark warning" },
      "800": { "hex": "#664101", "tailwind": "warning-800", "usage": "Darkest warning" }
    },
    "info": {
      "description": "Informational states (light blue)",
      "400": { "hex": "#0BA5EC", "tailwind": "info-400", "usage": "Info default" },
      "500": { "hex": "#0086C9", "tailwind": "info-500", "usage": "Info hover" }
    }
  },

  "spacing": {
    "description": "Spacing scale based on 4px grid",
    "base": "4px",
    "scale": {
      "1":  { "px": "4px",   "rem": "0.25rem", "usage": "Tight spacing, icon gaps" },
      "2":  { "px": "8px",   "rem": "0.5rem",  "usage": "Small gaps, padding" },
      "3":  { "px": "12px",  "rem": "0.75rem", "usage": "Medium-small gaps" },
      "4":  { "px": "16px",  "rem": "1rem",    "usage": "Default padding, gaps" },
      "5":  { "px": "20px",  "rem": "1.25rem", "usage": "Medium gaps" },
      "6":  { "px": "24px",  "rem": "1.5rem",  "usage": "Section padding" },
      "7":  { "px": "28px",  "rem": "1.75rem", "usage": "Large gaps" },
      "8":  { "px": "32px",  "rem": "2rem",    "usage": "Large padding" },
      "10": { "px": "40px",  "rem": "2.5rem",  "usage": "Section spacing" },
      "12": { "px": "48px",  "rem": "3rem",    "usage": "Large section spacing" },
      "16": { "px": "64px",  "rem": "4rem",    "usage": "Major sections" },
      "20": { "px": "80px",  "rem": "5rem",    "usage": "Page sections" },
      "24": { "px": "96px",  "rem": "6rem",    "usage": "Large page sections" },
      "32": { "px": "128px", "rem": "8rem",    "usage": "Hero sections" },
      "40": { "px": "160px", "rem": "10rem",   "usage": "Extra large spacing" },
      "48": { "px": "192px", "rem": "12rem",   "usage": "Maximum spacing" }
    }
  },

  "typography": {
    "fontFamily": {
      "sans": ["Inter", "ui-sans-serif", "system-ui", "sans-serif"]
    },
    "presets": {
      "display-lg": {
        "size": "56px",
        "lineHeight": 1,
        "letterSpacing": "-0.04em",
        "fontWeight": 700,
        "tailwindClass": "text-display-lg",
        "usage": "Hero headlines"
      },
      "display-sm": {
        "size": "48px",
        "lineHeight": 1,
        "letterSpacing": "-0.04em",
        "fontWeight": 700,
        "tailwindClass": "text-display-sm",
        "usage": "Large headlines"
      },
      "h1": {
        "size": "40px",
        "lineHeight": 1.2,
        "letterSpacing": "-0.04em",
        "fontWeight": 600,
        "tailwindClass": "text-h1",
        "usage": "Page titles"
      },
      "h2": {
        "size": "36px",
        "lineHeight": 1.2,
        "letterSpacing": "-0.04em",
        "fontWeight": 600,
        "tailwindClass": "text-h2",
        "usage": "Section headings"
      },
      "h3": {
        "size": "32px",
        "lineHeight": 1.2,
        "letterSpacing": "-0.02em",
        "fontWeight": 600,
        "tailwindClass": "text-h3",
        "usage": "Subsection headings"
      },
      "h4": {
        "size": "28px",
        "lineHeight": 1.2,
        "letterSpacing": "-0.02em",
        "fontWeight": 600,
        "tailwindClass": "text-h4",
        "usage": "Card titles"
      },
      "h5": {
        "size": "24px",
        "lineHeight": 1.2,
        "letterSpacing": "-0.02em",
        "fontWeight": 600,
        "tailwindClass": "text-h5",
        "usage": "Component headings"
      },
      "h6": {
        "size": "20px",
        "lineHeight": 1.2,
        "letterSpacing": "-0.02em",
        "fontWeight": 600,
        "tailwindClass": "text-h6",
        "usage": "Small headings"
      },
      "body-lg": {
        "size": "18px",
        "lineHeight": 1.45,
        "letterSpacing": "0",
        "fontWeight": 400,
        "tailwindClass": "text-body-lg",
        "usage": "Large body text, lead paragraphs"
      },
      "body-md": {
        "size": "16px",
        "lineHeight": 1.45,
        "letterSpacing": "0",
        "fontWeight": 400,
        "tailwindClass": "text-body-md",
        "usage": "Default body text"
      },
      "body-sm": {
        "size": "14px",
        "lineHeight": 1.45,
        "letterSpacing": "0",
        "fontWeight": 400,
        "tailwindClass": "text-body-sm",
        "usage": "Small body text, helper text"
      },
      "body-xs": {
        "size": "12px",
        "lineHeight": 1.45,
        "letterSpacing": "0",
        "fontWeight": 400,
        "tailwindClass": "text-body-xs",
        "usage": "Extra small text, footnotes"
      },
      "caption-lg": {
        "size": "14px",
        "lineHeight": 1.2,
        "letterSpacing": "0.12em",
        "fontWeight": 500,
        "textTransform": "uppercase",
        "tailwindClass": "text-caption-lg uppercase",
        "usage": "Large labels, section titles"
      },
      "caption-sm": {
        "size": "12px",
        "lineHeight": 1.2,
        "letterSpacing": "0.12em",
        "fontWeight": 500,
        "textTransform": "uppercase",
        "tailwindClass": "text-caption-sm uppercase",
        "usage": "Small labels"
      },
      "caption-xs": {
        "size": "10px",
        "lineHeight": 1.2,
        "letterSpacing": "0.16em",
        "fontWeight": 500,
        "textTransform": "uppercase",
        "tailwindClass": "text-caption-xs uppercase",
        "usage": "Tiny labels, badges"
      }
    }
  },

  "shadows": {
    "soft": {
      "description": "Subtle, soft shadows for elevated elements",
      "xxs": {
        "value": "0px 1.5px 4px -1px rgba(16, 25, 40, 0.07)",
        "tailwindClass": "shadow-soft-xxs",
        "usage": "Subtle card elevation"
      },
      "xs": {
        "value": "0px 2px 4px -1px rgba(16, 25, 40, 0.02), 0px 5px 13px -5px rgba(16, 25, 40, 0.05)",
        "tailwindClass": "shadow-soft-xs",
        "usage": "Light elevation"
      },
      "sm": {
        "value": "0px 10px 18px -2px rgba(16, 25, 40, 0.07)",
        "tailwindClass": "shadow-soft-sm",
        "usage": "Small dropdowns"
      },
      "md": {
        "value": "0px 0px 3px -1px rgba(16, 25, 40, 0.04), 0px 14px 22px -9px rgba(16, 25, 40, 0.14)",
        "tailwindClass": "shadow-soft-md",
        "usage": "Modals, popovers"
      },
      "lg": {
        "value": "0px 4px 6px -2px rgba(16, 25, 40, 0.03), 0px 16px 24px -4px rgba(16, 25, 40, 0.08)",
        "tailwindClass": "shadow-soft-lg",
        "usage": "Large elevated elements"
      },
      "xl": {
        "value": "0px 8px 8px -4px rgba(16, 25, 40, 0.03), 0px 24px 32px -4px rgba(16, 25, 40, 0.08)",
        "tailwindClass": "shadow-soft-xl",
        "usage": "Prominent elevation"
      },
      "2xl": {
        "value": "0px 32px 54px -12px rgba(16, 25, 40, 0.18)",
        "tailwindClass": "shadow-soft-2xl",
        "usage": "Large modals"
      },
      "3xl": {
        "value": "0px 40px 72px -12px rgba(16, 25, 40, 0.14)",
        "tailwindClass": "shadow-soft-3xl",
        "usage": "Maximum elevation"
      }
    },
    "hard": {
      "description": "Defined shadows with border effect",
      "xxs": {
        "value": "0px 2px 5px -2px rgba(16, 25, 40, 0.06), 0px 2px 7px 0px rgba(16, 25, 40, 0.05), 0px 0px 0px 1px rgba(16, 25, 40, 0.05)",
        "tailwindClass": "shadow-hard-xxs",
        "usage": "Buttons with border effect"
      },
      "xs": {
        "value": "0px 2px 12px -1px rgba(16, 25, 40, 0.1), 0px 2px 2px -1px rgba(16, 25, 40, 0.04), 0px 0px 0px 1px rgba(16, 25, 40, 0.05)",
        "tailwindClass": "shadow-hard-xs",
        "usage": "Input focus states"
      },
      "sm": {
        "value": "0px 6px 16px 0px rgba(16, 25, 40, 0.08), 0px 0px 0px 1px rgba(16, 25, 40, 0.05)",
        "tailwindClass": "shadow-hard-sm",
        "usage": "Cards with border"
      },
      "md": {
        "value": "0px 0px 3px -1px rgba(16, 25, 40, 0.04), 0px 16px 24px -6px rgba(16, 25, 40, 0.08), 0px 0px 0px 1px rgba(16, 25, 40, 0.05)",
        "tailwindClass": "shadow-hard-md",
        "usage": "Elevated cards with border"
      }
    }
  },

  "borderRadius": {
    "sm":   { "value": "4px",    "tailwindClass": "rounded-sm" },
    "md":   { "value": "6px",    "tailwindClass": "rounded-md" },
    "lg":   { "value": "8px",    "tailwindClass": "rounded-lg" },
    "xl":   { "value": "12px",   "tailwindClass": "rounded-xl" },
    "2xl":  { "value": "16px",   "tailwindClass": "rounded-2xl" },
    "full": { "value": "9999px", "tailwindClass": "rounded-full" }
  },

  "blur": {
    "xs": { "value": "2px",  "tailwindClass": "blur-xs" },
    "sm": { "value": "4px",  "tailwindClass": "blur-sm" },
    "md": { "value": "12px", "tailwindClass": "blur-md" },
    "lg": { "value": "16px", "tailwindClass": "blur-lg" },
    "xl": { "value": "20px", "tailwindClass": "blur-xl" }
  },

  "breakpoints": {
    "sm": { "value": "320px",  "description": "Mobile" },
    "md": { "value": "600px",  "description": "Tablet" },
    "lg": { "value": "1136px", "description": "Desktop" }
  },

  "componentTokens": {
    "button": {
      "primary": {
        "background": "primary-500",
        "backgroundHover": "primary-400",
        "backgroundActive": "primary-700",
        "backgroundDisabled": "grey-300",
        "text": "white",
        "textDisabled": "white"
      },
      "destructive": {
        "background": "error-500",
        "backgroundHover": "error-200",
        "text": "white"
      }
    },
    "input": {
      "borderDefault": "grey-300",
      "borderHover": "primary-100",
      "borderFocus": "primary-200",
      "borderError": "error-200",
      "borderSuccess": "success-200",
      "backgroundDefault": "white",
      "backgroundReadonly": "grey-100",
      "backgroundDisabled": "grey-50"
    },
    "badge": {
      "success": { "background": "success-50", "text": "success-700" },
      "error": { "background": "error-50", "text": "error-700" },
      "warning": { "background": "warning-50", "text": "warning-700" },
      "neutral": { "background": "grey-100", "text": "grey-700" }
    }
  }
}
