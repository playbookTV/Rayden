{
  "name": "create-rayden-app",
  "version": "0.2.1",
  "description": "Create Rayden UI applications with one command",
  "type": "module",
  "bin": {
    "create-rayden-app": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "keywords": [
    "cli",
    "scaffold",
    "create",
    "rayden",
    "rayden-ui",
    "react",
    "vite",
    "nextjs",
    "tailwindcss",
    "tailwind",
    "component-library",
    "starter",
    "template",
    "boilerplate"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "picocolors": "^1.0.0",
    "fs-extra": "^11.2.0",
    "ejs": "^3.1.9"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.10.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/raydenui/rayden"
  }
}
